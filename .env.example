# ============================================================
# RDC Server — Environment Variables
# ============================================================
# Copy this file to .env (or export the variables in your shell)
# and adjust the values for your environment.
#
# Required variables (no defaults — app will refuse to start without them):
#   DB_HOST, DB_USER, DB_PASSWORD
#
# Optional variables (have safe defaults):
#   DB_PORT, DB_NAME, SERVER_ADDR, MIGRATIONS_DROP_RECREATE,
#   LOG_LEVEL, LW_BASE_URL, LW_API_KEY, LW_USE_MOCK, LW_TIMEOUT_S
# ============================================================

# --- Database (SQL Server) ---
# REQUIRED. Hostname or IP of the SQL Server instance.
DB_HOST=172.17.1.24

# REQUIRED. SQL Server login user. Do NOT use sa in production.
DB_USER=rdc_test

# REQUIRED. SQL Server login password. In production, load this from a
# secret manager (Vault, AWS Secrets Manager, Kubernetes secrets, etc.)
# rather than a plaintext .env file.
DB_PASSWORD=change-me-in-production

# SQL Server port (default 1433).
DB_PORT=1433

# Database name (default RDC).
DB_NAME=RDC

# --- Server ---
# HTTP listen address. Use ":8000" to listen on all interfaces,
# or "127.0.0.1:8000" to listen on localhost only.
SERVER_ADDR=:8000

# --- Migrations ---
# DANGER: when true, the migration runner will DROP all tables and recreate
# them on every startup. Useful for dev/test where you want a clean slate.
# MUST be false in production — otherwise you will lose all data on restart.
MIGRATIONS_DROP_RECREATE=true

# --- Logging ---
# Log level for structured (slog) JSON logger.
# One of: debug, info, warn, error
LOG_LEVEL=info

# --- LW Provider (T-2.12) ---
# When true, the LW provider reads from the local DB (mock_lms_loans table)
# and returns canned responses for router endpoints. Set to false in
# production to use the real LW system via HTTP.
LW_USE_MOCK=true

# Base URL of the LW system. Only used when LW_USE_MOCK=false.
# Example: http://lw.internal.example.com:8080
LW_BASE_URL=http://localhost:8080

# API key for LW authentication. Only used when LW_USE_MOCK=false.
# In production, load this from a secret manager.
LW_API_KEY=

# HTTP timeout for LW calls, in seconds (default 30).
LW_TIMEOUT_S=30
